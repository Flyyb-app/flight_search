{
  "version": 2,
  "routes": [
    {
      "src": "/css/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/js/$1"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|svg|ico|webp))",
      "headers": { "Cache-Control": "public, max-age=2592000" },
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "headers": { "Cache-Control": "no-cache" },
      "dest": "/index.html"
    }
  ]
}
